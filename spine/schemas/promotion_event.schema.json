{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sandy-chaos.local/spine/promotion_event.schema.json",
  "title": "Sandy Chaos Promotion Event",
  "type": "object",
  "required": ["id", "date", "concepts", "from_status", "to_status", "promotion_target", "basis", "disposition"],
  "properties": {
    "id": {"type": "string", "pattern": "^SC-PROMOTE-[0-9]{8}-[0-9]{2}$"},
    "date": {"type": "string", "format": "date"},
    "concepts": {"type": "array", "items": {"type": "string", "pattern": "^SC-CONCEPT-[0-9]{4}$"}, "minItems": 1},
    "from_status": {"type": "string", "enum": ["seed", "draft", "pressure-testing", "validated-partial", "canonical", "archived", "deprecated", "killed"]},
    "to_status": {"type": "string", "enum": ["seed", "draft", "pressure-testing", "validated-partial", "canonical", "archived", "deprecated", "killed"]},
    "promotion_target": {"type": "string", "enum": ["docs/canonical", "docs/archive", "code/core", "code/experiment", "tests", "workflow", "config", "memory-only", "public-site", "ygg-bridge", "ygg-native-candidate"]},
    "basis": {"type": "string", "minLength": 1},
    "disposition": {"type": "string", "enum": ["DOC_PROMOTE", "CODE_PROMOTE", "TEST_PROMOTE", "ARCHIVE", "MERGE_INTO_EXISTING", "YGG_BRIDGE", "KILL"]}
  },
  "additionalProperties": false
}
