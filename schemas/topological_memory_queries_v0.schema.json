{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/yanmo42/sandy-chaos/schemas/topological_memory_queries_v0.schema.json",
  "title": "TopologicalMemoryBenchmarkQueriesV0",
  "type": "object",
  "required": ["schema_version", "generated_at", "queries"],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "topological-memory-queries-v0"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "notes": {
      "type": "string"
    },
    "queries": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/query" }
    }
  },
  "$defs": {
    "query": {
      "type": "object",
      "required": ["id", "question", "category", "expected_nodes"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "question": {
          "type": "string",
          "minLength": 1
        },
        "category": {
          "type": "string",
          "enum": [
            "resume_next",
            "origin_trace",
            "promotion_target",
            "dependency_path",
            "validation_surface",
            "policy_context",
            "checkpoint_lookup"
          ]
        },
        "difficulty": {
          "type": "string",
          "enum": ["easy", "medium", "hard"]
        },
        "time_horizon": {
          "type": "string",
          "enum": ["fast", "meso", "slow"]
        },
        "expected_nodes": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string" }
        },
        "expected_any_nodes": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string" }
        },
        "disallowed_nodes": {
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "string" }
        },
        "notes": {
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
