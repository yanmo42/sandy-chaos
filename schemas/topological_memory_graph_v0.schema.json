{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/yanmo42/sandy-chaos/schemas/topological_memory_graph_v0.schema.json",
  "title": "TopologicalMemoryGraphV0",
  "type": "object",
  "required": ["schema_version", "generated_at", "nodes", "edges", "traces"],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "topological-memory-v0"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "notes": {
      "type": "string"
    },
    "nodes": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/node" }
    },
    "edges": {
      "type": "array",
      "items": { "$ref": "#/$defs/edge" }
    },
    "traces": {
      "type": "array",
      "items": { "$ref": "#/$defs/trace" }
    }
  },
  "$defs": {
    "surface": {
      "type": "string",
      "enum": [
        "sandy-chaos",
        "ygg",
        "spine",
        "site",
        "discord",
        "amoeba",
        "raven",
        "other"
      ]
    },
    "node": {
      "type": "object",
      "required": ["id", "kind", "title", "path", "summary", "tags", "created_at", "updated_at"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "type": "string",
          "enum": [
            "repo",
            "doc",
            "plan",
            "script",
            "code",
            "test",
            "checkpoint",
            "session",
            "channel",
            "task",
            "workflow",
            "state",
            "concept",
            "spine-concept",
            "spine-pressure"
          ]
        },
        "surface": { "$ref": "#/$defs/surface" },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "path": {
          "type": "string",
          "minLength": 1
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "tags": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "updated_at": {
          "type": "string",
          "format": "date-time"
        }
      },
      "additionalProperties": false
    },
    "edge": {
      "type": "object",
      "required": ["id", "source", "target", "relation", "weight"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "source": {
          "type": "string",
          "minLength": 1
        },
        "target": {
          "type": "string",
          "minLength": 1
        },
        "relation": {
          "type": "string",
          "enum": [
            "depends_on",
            "derived_from",
            "documented_in",
            "implemented_in",
            "tested_by",
            "promotes_to",
            "mentioned_in",
            "checkpointed_by",
            "resumes",
            "human_touched",
            "same_lane_as"
          ]
        },
        "weight": {
          "type": "number",
          "exclusiveMinimum": 0,
          "maximum": 1
        }
      },
      "additionalProperties": false
    },
    "trace": {
      "type": "object",
      "required": ["id", "subject_type", "subject_id", "event_type", "timestamp", "weight"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "subject_type": {
          "type": "string",
          "enum": ["node", "edge"]
        },
        "subject_id": {
          "type": "string",
          "minLength": 1
        },
        "event_type": {
          "type": "string",
          "enum": [
            "create",
            "edit",
            "review",
            "pressure",
            "checkpoint",
            "promote",
            "promotion",
            "test",
            "test_run",
            "todo",
            "resume",
            "retrieval_hit",
            "retrieval_miss",
            "run"
          ]
        },
        "timestamp": {
          "type": "string",
          "format": "date-time"
        },
        "weight": {
          "type": "number",
          "exclusiveMinimum": 0,
          "maximum": 1
        },
        "source_surface": { "$ref": "#/$defs/surface" },
        "disposition": {
          "type": "string",
          "enum": [
            "DROP_LOCAL",
            "LOG_ONLY",
            "TODO_PROMOTE",
            "DOC_PROMOTE",
            "POLICY_PROMOTE",
            "ESCALATE"
          ]
        },
        "confidence_tier": {
          "type": "string",
          "enum": ["defensible", "plausible", "speculative"]
        },
        "half_life_hours": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "note": {
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
