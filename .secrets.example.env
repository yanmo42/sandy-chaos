# Copy this file to .secrets.local.env and fill values.
# .secrets.local.env is gitignored and loaded by systemd automation.

# Telegram bot token (required for --send-telegram)
OPENCLAW_TELEGRAM_BOT_TOKEN=

# Target chat/user id for Telegram messages
OPENCLAW_TELEGRAM_TARGET=

# Optional explicit OpenClaw binary path override
# OPENCLAW_BIN=${HOME}/.npm-global/bin/openclaw

# Optional git auto-push controls (planned)
# GIT_AUTOPUSH_ENABLED=0
# GIT_AUTOPUSH_REMOTE=origin
# GIT_AUTOPUSH_BRANCH=main
# GIT_AUTOPUSH_REQUIRE_CLEAN_BASE=1
# GIT_AUTOPUSH_VALIDATE_CMD=./venv/bin/python -m unittest -q
